# Python bytecode and cache artifacts
__pycache__/
*.py[cod]
*$py.class

# Radar example captures — keep JSON; omit large video binaries
software/layer1_radar/examples/data/*.mp4

# Local/vendor SDK copies (testing only; not part of product tree)
software/vendor/

# macOS Finder metadata
.DS_Store

# Python tooling
.pytest_cache/
.venv/

# Layer 8 frontend caches and build artifacts
software/layer8_ui/frontend/.vite/
software/layer8_ui/frontend/node_modules/
software/layer8_ui/frontend/dist/
software/layer8_ui/frontend/*.tsbuildinfo
software/layer8_ui/frontend/vite.config.js
software/layer8_ui/frontend/vite.config.d.ts

# Layer 8 legacy runtime outputs
software/layer8_ui/legacy/logs/*
!software/layer8_ui/legacy/logs/.gitkeep
software/layer8_ui/legacy/artifacts/*
!software/layer8_ui/legacy/artifacts/.gitkeep

# Playwright artifacts
software/layer8_ui/frontend/test-results/

# Personal local git helpers (do not version)
scripts/git-whoami.sh
scripts/githooks/pre-commit

# Layer 8 runtime local state
software/layer8_ui/ui_prefs.json
software/layer8_ui/logs/*.log
